#!/usr/bin/env bash
# astack setup — build browser binary + register skills with Claude Code / Codex
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install it: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

ASTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$ASTACK_DIR")"
BROWSE_BIN="$ASTACK_DIR/browse/dist/browse"
if [ ! -e "$BROWSE_BIN" ] && [ -e "$ASTACK_DIR/browse/dist/browse.exe" ]; then
  BROWSE_BIN="$ASTACK_DIR/browse/dist/browse.exe"
fi

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

if [ "$IS_WINDOWS" -eq 1 ] && ! command -v node >/dev/null 2>&1; then
  echo "Error: Node.js is required on Windows." >&2
  echo "astack uses Bun as the primary runtime, but setup needs Node.js on Windows to verify Playwright/Chromium." >&2
  echo "Install Node.js: https://nodejs.org/" >&2
  exit 1
fi

# ─── Parse --host flag ─────────────────────────────────────────
HOST="claude"
while [ $# -gt 0 ]; do
  case "$1" in
    --host) HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|copilot|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, copilot, or auto)" >&2; exit 1 ;;
esac

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_COPILOT=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  # If neither found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "copilot" ]; then
  INSTALL_COPILOT=1
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$ASTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$ASTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$ASTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$ASTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$ASTACK_DIR/bun.lock" ] && [ "$ASTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$ASTACK_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$ASTACK_DIR/browse/dist/.version" ]; then
    git -C "$ASTACK_DIR" rev-parse HEAD > "$ASTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "astack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$ASTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the astack directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "astack setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$ASTACK_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "astack setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "astack setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.astack global state directory exists
mkdir -p "$HOME/.astack/projects"

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
link_claude_skill_dirs() {
  local astack_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$astack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$skill_name" = "node_modules" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink; skip if a real file/directory exists
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "astack/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from generated .agents/skills/* directories (the Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local astack_dir="$1"
  local skills_dir="$2"
  local agents_dir="$astack_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      if [ "$skill_name" = "astack" ]; then
        continue
      fi
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi

  for legacy_target in "$skills_dir"/astack-*; do
    [ -e "$legacy_target" ] || continue
    legacy_name="$(basename "$legacy_target")"
    if [ ! -e "$agents_dir/$legacy_name/SKILL.md" ]; then
      rm -rf "$legacy_target"
    fi
  done
}

link_copilot_skill_dirs() {
  local astack_dir="$1"
  local skills_dir="$2"
  local copilot_dir="$astack_dir/.copilot/skills"
  local linked=()

  if [ ! -d "$copilot_dir" ]; then
    echo "  warning: no .copilot/skills/ directory found — run 'bun run gen:skill-docs --host copilot' first" >&2
    return 1
  fi

  for skill_dir in "$copilot_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      if [ "$skill_name" = "astack" ]; then
        continue
      fi
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi

  for legacy_target in "$skills_dir"/astack-*; do
    [ -e "$legacy_target" ] || continue
    legacy_name="$(basename "$legacy_target")"
    if [ ! -e "$copilot_dir/$legacy_name/SKILL.md" ]; then
      rm -rf "$legacy_target"
    fi
  done
}

# ─── Helper: create a slim astack runtime root without nested skill dirs ──
# Codex recursively discovers SKILL.md files under ~/.codex/skills. If the root
# astack install points at the whole repo, every source skill folder shows up a
# second time. Keep the root install to runtime-only assets.
create_runtime_root() {
  local source_skill_md="$1"
  local target_root="$2"
  mkdir -p "$target_root"

  cp "$source_skill_md" "$target_root/SKILL.md"

  if [ "$ASTACK_DIR" != "$target_root" ]; then
    [ -f "$ASTACK_DIR/VERSION" ] && cp "$ASTACK_DIR/VERSION" "$target_root/VERSION"
    [ -f "$ASTACK_DIR/CHANGELOG.md" ] && cp "$ASTACK_DIR/CHANGELOG.md" "$target_root/CHANGELOG.md"
  fi
  printf '%s\n' "$ASTACK_DIR" > "$target_root/.astack-source-path"

  local bin_dst="$target_root/bin"
  if [ -L "$bin_dst" ] || [ ! -e "$bin_dst" ]; then
    ln -snf "$ASTACK_DIR/bin" "$bin_dst"
  fi

  mkdir -p "$target_root/browse"
  local browse_dist_dst="$target_root/browse/dist"
  if [ -L "$browse_dist_dst" ] || [ ! -e "$browse_dist_dst" ]; then
    ln -snf "$ASTACK_DIR/browse/dist" "$browse_dist_dst"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    link_claude_skill_dirs "$ASTACK_DIR" "$SKILLS_DIR"
    echo "astack ready (claude)."
    echo "  browse: $BROWSE_BIN"
  else
    echo "astack ready (claude)."
    echo "  browse: $BROWSE_BIN"
    echo "  (skipped skill symlinks — not inside .claude/skills/)"
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  CODEX_SKILLS="$HOME/.codex/skills"
  CODEX_ASTACK="$CODEX_SKILLS/astack"
  mkdir -p "$CODEX_SKILLS"

  # Install a slim astack runtime root instead of symlinking the full repo.
  # This prevents Codex from discovering every source skill twice.
  if [ "$ASTACK_DIR" = "$CODEX_ASTACK" ]; then
    # Legacy in-place Codex install: keep the source checkout at the runtime root.
    printf '%s\n' "$ASTACK_DIR" > "$CODEX_ASTACK/.astack-source-path"
  else
    if [ -e "$CODEX_ASTACK/setup" ] && [ -e "$CODEX_ASTACK/package.json" ]; then
      rm -rf "$CODEX_ASTACK"
    elif [ -L "$CODEX_ASTACK" ] && [ "$(readlink "$CODEX_ASTACK" 2>/dev/null)" = "$ASTACK_DIR" ]; then
      rm -f "$CODEX_ASTACK"
    fi
    mkdir -p "$CODEX_ASTACK"
    create_runtime_root "$ASTACK_DIR/.agents/skills/astack/SKILL.md" "$CODEX_ASTACK"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$ASTACK_DIR" "$CODEX_SKILLS"

  echo "astack ready (codex)."
  echo "  browse: $BROWSE_BIN"
  echo "  codex skills: $CODEX_SKILLS"
fi

# 6. Create .agents/ sidecar symlinks (useful for Codex/Gemini/Cursor workspace-local)
if [ "$INSTALL_CODEX" -eq 1 ]; then
  # Detect repo root: if we're inside a skills directory, go up two levels
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    REPO_ROOT="$(dirname "$SKILLS_DIR")"
  else
    REPO_ROOT="$ASTACK_DIR"
  fi
  create_runtime_root "$ASTACK_DIR/.agents/skills/astack/SKILL.md" "$REPO_ROOT/.agents/skills/astack"
fi

# 7. Install for Copilot
if [ "$INSTALL_COPILOT" -eq 1 ]; then
  COPILOT_SKILLS="$HOME/.copilot/skills"
  COPILOT_ASTACK="$COPILOT_SKILLS/astack"
  mkdir -p "$COPILOT_SKILLS"

  if [ ! -f "$ASTACK_DIR/.copilot/skills/astack/SKILL.md" ]; then
    echo "astack setup failed: Copilot generated skills are missing. Run 'bun run gen:skill-docs --host copilot' or 'bun run build' first." >&2
    exit 1
  fi

  if [ -e "$COPILOT_ASTACK/setup" ] && [ -e "$COPILOT_ASTACK/package.json" ]; then
    rm -rf "$COPILOT_ASTACK"
  elif [ -L "$COPILOT_ASTACK" ] && [ "$(readlink "$COPILOT_ASTACK" 2>/dev/null)" = "$ASTACK_DIR" ]; then
    rm -f "$COPILOT_ASTACK"
  fi
  mkdir -p "$COPILOT_ASTACK"
  create_runtime_root "$ASTACK_DIR/.copilot/skills/astack/SKILL.md" "$COPILOT_ASTACK"
  link_copilot_skill_dirs "$ASTACK_DIR" "$COPILOT_SKILLS"

  echo "astack ready (copilot)."
  echo "  browse: $BROWSE_BIN"
  echo "  copilot skills: $COPILOT_SKILLS"
fi

# 8. First-time welcome + legacy cleanup
if [ ! -d "$HOME/.astack" ]; then
  mkdir -p "$HOME/.astack"
  echo "  Welcome! Run /astack-upgrade anytime to stay current."
fi
rm -f /tmp/astack-latest-version
